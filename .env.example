# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=key_here

# Gemini model to use (gemini-2.0-flash-lite is cheapest; gemini-2.0-flash or gemini-1.5-pro for higher quality)
GEMINI_MODEL=gemini-1.5-pro

# Max requests per minute sent to Gemini (free tier = 15, paid tier can be much higher)
GEMINI_RPM=15

# Minimum match score (1-10) to consider a job worth applying to
MIN_MATCH_SCORE=6

# Maximum jobs to scrape per site per run
MAX_JOBS_PER_SITE=20

# Set to "true" to run the browser headlessly (not recommended — you need to interact)
BROWSER_HEADLESS=false

# ── Docker worker settings ────────────────────────────────────────────────────
# Gemini API key for the headless Docker worker (plaintext; DPAPI doesn't work in Linux)
GEMINI_API_KEY=AIzaSy...

# Path to your local JobHunter data directory containing browser profile, config, CV, etc.
# Point to %LocalAppData%\JobHunter to reuse your existing sessions:
#   JOBHUNTER_LOCAL_DATA=C:\Users\YourName\AppData\Local\JobHunter
# Default ./data uses the example folder in this repo.
JOBHUNTER_LOCAL_DATA=./data

# Optional search overrides (ignored if /data/search.json exists)
# SEARCH_TITLE=Senior Software Engineer
# SEARCH_LOCATION=Remote
# SEARCH_KEYWORDS=C# .NET backend
# SEARCH_MIN_SCORE=6
# SEARCH_MAX_JOBS=20
