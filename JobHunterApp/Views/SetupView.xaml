<UserControl x:Class="JobHunterApp.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:JobHunterApp.ViewModels"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="680">

            <!-- Header -->
            <TextBlock Text="Setup" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Configure your API key, CV file, and recommendation letters."
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,28"/>

            <!-- Browser Mode -->
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="BROWSER" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton Content="Use my browser (recommended)"
                                     IsChecked="{Binding BrowserMode,
                                         Converter={StaticResource EnumBoolConverter},
                                         ConverterParameter=ConnectToBrowser}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     Margin="0,0,24,0"/>
                        <RadioButton Content="Managed profile"
                                     IsChecked="{Binding BrowserMode,
                                         Converter={StaticResource EnumBoolConverter},
                                         ConverterParameter=Managed}"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <TextBlock Text="Connect to your existing Chrome/Edge session so you stay logged in to LinkedIn, Indeed, etc."
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Debug port"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2"
                                 Text="{Binding CdpPort, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                        <Button Grid.Column="4" Content="Launch Browser for Automation"
                                Command="{Binding LaunchBrowserCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="14,6"/>
                    </Grid>

                    <TextBlock Text="{Binding BrowserStatus}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="11" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BrowserStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- API Key -->
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="GEMINI API KEY" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,12"/>
                    <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Text="Get a free key at aistudio.google.com/app/apikey"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" Margin="0,6,0,0"/>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Model" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding GeminiModel, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Requests / min" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding GeminiRpm, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Free tier" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="15 RPM" Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,7,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- CV -->
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="CV / RESUME" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource BackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="5" Padding="10,7">
                            <TextBlock Text="{Binding CvPath}" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" FontSize="12"
                                       ToolTip="{Binding CvPath}"/>
                        </Border>
                        <Button Grid.Column="2" Content="Browse…"
                                Command="{Binding BrowseCvCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Recommendation Letters -->
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="RECOMMENDATION LETTERS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Content="+ Add Letter" DockPanel.Dock="Right"
                                Command="{Binding AddLetterCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="12,5"/>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding Letters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <Button DockPanel.Dock="Right"
                                                    Content="✕" Width="26" Height="26"
                                                    Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.RemoveLetterCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <TextBlock Text="{Binding Label, StringFormat='Letter: {0}'}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Label" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Key" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12" FontFamily="Consolas"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="4" Padding="8,5">
                                                <TextBlock Text="{Binding Path}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="11" ToolTip="{Binding Path}"/>
                                            </Border>
                                            <Button Grid.Column="2" Content="Browse…"
                                                    Style="{StaticResource SecondaryButton}" Padding="10,5"
                                                    Command="{Binding DataContext.BrowseLetterCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Save -->
            <DockPanel>
                <TextBlock Text="{Binding SaveStatus}" DockPanel.Dock="Right"
                           Foreground="{StaticResource SuccessBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Content="Save Configuration" Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}" Padding="24,10" FontSize="14"/>
            </DockPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
