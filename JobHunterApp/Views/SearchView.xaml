<UserControl x:Class="JobHunterApp.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="560">

            <TextBlock Text="Search" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Configure your job search and start the hunt."
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,28"/>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="SEARCH PARAMETERS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="Job title" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Style="{StaticResource AutoComboBox}"
                              Text="{Binding JobTitle, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding JobTitleSuggestions}"
                              Margin="0,0,0,12"
                              ToolTip="The role you are looking for, e.g. 'Software Engineer' or 'Product Manager'"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Location" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource AutoComboBox}"
                                      Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding LocationSuggestions}"
                                      ToolTip="City, country, or 'Remote'. Used to filter job results on each site."/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Keywords (optional)" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource AutoComboBox}"
                                      Text="{Binding Keywords, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding KeywordsSuggestions}"
                                      ToolTip="Extra words added to the search query, e.g. 'React TypeScript'. Leave blank to search by job title only."/>
                        </StackPanel>
                    </Grid>

                    <!-- Sites -->
                    <TextBlock Text="Sites" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Content="LinkedIn" IsChecked="{Binding UseLinkedIn}" Margin="0,0,20,0"
                                  ToolTip="Scrape job listings from LinkedIn Jobs (browser + login)."/>
                        <CheckBox Content="Indeed" IsChecked="{Binding UseIndeed}"
                                  ToolTip="Scrape job listings from Indeed (browser + login)."/>
                    </StackPanel>

                    <TextBlock Text="API sources (headless, no login)" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox Content="Remotive" IsChecked="{Binding UseRemotive}" Margin="0,0,16,0"
                                  ToolTip="Free remote-jobs API. No login."/>
                        <CheckBox Content="RemoteOK" IsChecked="{Binding UseRemoteOk}" Margin="0,0,16,0"
                                  ToolTip="Free remote/tech jobs API. No login."/>
                        <CheckBox Content="Arbeitnow" IsChecked="{Binding UseArbeitnow}" Margin="0,0,16,0"
                                  ToolTip="Free EU + remote jobs API. No login."/>
                        <CheckBox Content="Adzuna" IsChecked="{Binding UseAdzuna}"
                                  ToolTip="Broad aggregator. Needs free app id + key in Setup."/>
                    </StackPanel>

                    <!-- Quick-apply filters -->
                    <TextBlock Text="Quick-apply filters" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,0,0,8"/>
                    <CheckBox Content="LinkedIn Easy Apply only"
                              IsChecked="{Binding LinkedInEasyApplyOnly}"
                              Margin="0,0,0,8"
                              ToolTip="Only include LinkedIn jobs that have the Easy Apply button. These are applied to entirely inside LinkedIn — no external site redirect."/>
                    <CheckBox Content="Indeed Apply only"
                              IsChecked="{Binding IndeedApplyOnly}"
                              Margin="0,0,0,4"
                              ToolTip="Only include Indeed jobs that support Indeed Apply. These let you submit your resume directly on Indeed without leaving the site."/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="LIMITS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding MinScore, StringFormat='Min score: {0}/10'}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <Slider Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding MinScore}"
                                    ToolTip="Jobs scored below this threshold by the AI are hidden from results. Higher = stricter filter."/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding MaxJobsPerSite, StringFormat='Max jobs/site: {0}'}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <Slider Minimum="5" Maximum="50" TickFrequency="5" IsSnapToTickEnabled="True"
                                    Value="{Binding MaxJobsPerSite}"
                                    ToolTip="Maximum number of job listings to scrape from each site per run. Higher values take longer but give more results."/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="APPLIED JOBS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <CheckBox Content="Skip jobs I already applied to"
                              IsChecked="{Binding SkipAppliedJobs}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="0,0,0,8"
                              ToolTip="Automatically exclude jobs from your applied history to avoid re-processing."/>
                    <Button Content="Clear Applied History"
                            Command="{Binding ClearAppliedHistoryCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="12,6"
                            ToolTip="Reset the record of applied jobs. Use if you want to re-apply to past applications."/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Start Job Hunt →" Command="{Binding StartCommand}"
                        Style="{StaticResource SuccessButton}" Padding="24,12" FontSize="15"
                        ToolTip="Scrape jobs, score them with AI, then walk you through applying to the ones you select."/>
                <TextBlock Text="{Binding ValidationMessage}"
                           Foreground="{StaticResource WarningBrush}"
                           FontSize="12" VerticalAlignment="Center"
                           Margin="16,0,0,0" TextWrapping="Wrap" MaxWidth="260">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ValidationMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
